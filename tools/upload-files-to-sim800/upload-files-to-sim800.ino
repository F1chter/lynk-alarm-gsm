void loop() {
  delay(10);
  if (Serial1.available()) { Serial.write(Serial1.read()); }
  if (Serial.available()) { Serial1.write(Serial.read()); }
}

bool uploadFile(char* fileInBase64, String fileName) {
  int fileLength = strlen(fileInBase64);

  int decodedLengthVar = decodedLength(fileInBase64, fileLength);
  if (decodedLengthVar <= 0) {
    Serial.println("Invalid input string");
    return false;
  }
  char decodedString[decodedLengthVar + 1];
  int result = decodeFromBase64(decodedString, fileInBase64, fileLength);
  Serial.print("decodedLengthVar:\t");
  Serial.print(decodedLengthVar);
  Serial.print("\tresult:\t");
  Serial.println(result);
  if (decodedLengthVar != result) return false;
  String command = String("+FSCREATE=C:\\User\\");
  command.concat(fileName);
  sendAT(command);
  if (readFromModemUntilOK() != 1) return false;
  command = String("+FSWRITE=C:\\User\\");
  command.concat(fileName);
  command.concat(",0,");
  command.concat(decodedLengthVar);
  command.concat(",10");
  sendAT(command);
  String buffer;
  if (readFromModem(100L, buffer, ">") != 1) return false;
  for (int i = 0; i < decodedLengthVar; i++) {
    Serial1.write((uint8_t)decodedString[i]);
  }
  Serial1.write("\r\n");
  Serial1.flush();
  return readFromModemUntilOK() == 1;
}
